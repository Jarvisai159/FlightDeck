# ===========================================
# FlightDeck Configuration
# Copy this file to .env and fill in values
# ===========================================

# --- Database ---
# SQLite (development): sqlite:///./flightdeck.db
# PostgreSQL (production): postgresql+asyncpg://user:pass@localhost:5432/flightdeck
DATABASE_URL=sqlite+aiosqlite:///./flightdeck.db

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- JWT Authentication ---
JWT_SECRET_KEY=change-me-to-a-random-64-char-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=10080

# --- Google OAuth ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:5173/auth/google/callback

# --- Email (Gmail SMTP) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=jarvis159@gmail.com
SMTP_PASSWORD=
SMTP_FROM_EMAIL=jarvis159@gmail.com
SMTP_FROM_NAME=FlightDeck

# --- API Keys (Free Tiers) ---
AVIATIONSTACK_API_KEY=
OPENSKY_USERNAME=
OPENSKY_PASSWORD=
KIWI_TEQUILA_API_KEY=

# --- Application ---
APP_NAME=FlightDeck
APP_ENV=development
APP_DEBUG=true
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:8000
CORS_ORIGINS=["http://localhost:5173"]

# --- Scraper Settings ---
SCRAPER_DEFAULT_TIMEOUT=30
SCRAPER_CACHE_TTL_LIVE=60
SCRAPER_CACHE_TTL_HISTORICAL=86400
SCRAPER_MAX_RETRIES=3

# --- Google AdSense ---
ADSENSE_CLIENT_ID=
ADSENSE_SLOT_SIDEBAR=
ADSENSE_SLOT_BANNER=
